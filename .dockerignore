# Keep the build context small and never bake data/secrets into the image.
.git
.gitignore
Dockerfile
docker-compose.yml

# Runtime state / data — lives in a volume, not the image.
data/
logs/
testrun/

# Secrets & local config
.env
.env.local
server_creds.txt

# Build output / archives / junk
bin/
*.zip
*.exe
*.exe~

# Docs & scripts not needed at runtime (openapi.yaml is embedded in the binary)
*.md
plan.md
archi_preview.md
preflight.py
