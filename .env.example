# ──────────────────────────────────────────────────────────────────────
# go-suggest-neo configuration
#
# Copy this file to `.env` at the working directory where you run
# neo-server and edit whatever you want to override. OS environment
# variables take precedence over `.env` values.
#
# Every line is the DEFAULT. Delete or uncomment what you want to change.
# Full reference: plan.md §12.
# ──────────────────────────────────────────────────────────────────────

# ── 12.1 Server ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8001
LOG_LEVEL=info
LOG_FILE=logs/go-suggest.log
LOG_MAX_SIZE_MB=5                  # rotate once the active log reaches this size
LOG_MAX_BACKUPS=10                 # number of rotated files to keep
LOG_MAX_AGE_DAYS=0                 # 0 = no age-based deletion
LOG_COMPRESS=false                 # gzip rotated files
DATA_DIR=data
CORS_ORIGINS=*
# SWAGGER_HOST=example.com:8001     # override when behind a proxy

# ── 12.2 Query path ──────────────────────────────────────────────────
MIN_QUERY_LEN=2                    # queries below this return 400
MAX_QUERY_LATENCY_MS=200           # per-request context.Deadline ceiling
DEFAULT_LIMIT=10
MAX_LIMIT=100

# ── 12.3 HotTrieCache ────────────────────────────────────────────────
WORD_CAP=100000                    # total words across all hot tries (shared pool)
PROMOTION_THRESHOLD=20             # hits in window before a prefix is promoted
PROMOTION_WINDOW_SEC=60            # sliding window for hit counting
PROMOTION_MAX_WORDS=50000          # cap on words loaded per promoted trie
PROMOTION_QUEUE_SIZE=256           # pending-promotion channel depth
PROMOTION_WORKERS=1                # concurrent promotion goroutines

# ── 12.4 QueryLedger + snapshot (warm-restart mitigation A) ──────────
LEDGER_IDLE_TTL_SEC=600            # drop counters idle for this long
LEDGER_SNAPSHOT_INTERVAL_SEC=60    # how often to dump ledger.snapshot.gob
# LEDGER_SNAPSHOT_PATH=            # empty = <DATA_DIR>/<list>/ledger.snapshot.gob

# ── 12.5 Pinned prefixes (warm-restart mitigation B) ─────────────────
# PINNED_PREFIXES_FILE=            # empty = <DATA_DIR>/<list>/pinned_prefixes.txt
PINNED_WARMUP_TIMEOUT_SEC=30       # cap on synchronous warmup before Listen
PINNED_WARMUP_ENABLED=true         # set false to skip synchronous warmup

# ── 12.6 Corpus on disk ──────────────────────────────────────────────
CORPUS_SORT_CHUNK_MB=256           # memory per chunk during bootstrap external sort
SKIP_INDEX_STRIDE=4096             # one skip-index entry per N sorted lines
CORPUS_READ_BUFFER_KB=64           # bufio scanner buffer for disk scans
CORPUS_WARM_ON_BOOT=true           # prime OS page cache (Windows AV mitigation)

# ── 12.7 UsageTracker (long-term, for prune decisions) ───────────────
USAGE_TRACKER_ENABLED=true         # master switch
USAGE_PREFIX_DEPTH=3               # depth for prefixHits keys (2=coarser, 4=finer)
USAGE_SURFACED_ENABLED=true        # toggle per-word "ever surfaced" set
USAGE_SNAPSHOT_INTERVAL_SEC=300    # how often to write usage.stats.gob

# ── 12.8 Corpus lifecycle ────────────────────────────────────────────
CORPUS_VERSIONS_KEPT=3             # retained versions for rollback
PRUNE_MAX_HITS=0                   # default cutoff for /corpus/apply?mode=prune
# CORPUS_STAGING_DIR=              # empty = <DATA_DIR>/<list>/versions/staging
APPLY_MIGRATE_USAGE=true           # preserve usage stats across apply
RESTART_FLUSH_TIMEOUT_SEC=10       # max time /restart waits for snapshots to flush

# ── 12.9 Security (admin endpoints) ──────────────────────────────────
# If ADMIN_TOKEN is empty, every admin endpoint returns 503 (fail-closed).
# Clients pass the token via:
#     X-API-Key: <token>            (preferred)
#     Authorization: Bearer <token> (also accepted)
# Use >= 32 random chars. Rotate by changing the env var and restarting.
ADMIN_TOKEN=1234567890abcdef1234567890abcdef
# Optional defense-in-depth: comma-separated IPs and/or CIDRs allowed to
# call admin endpoints. Empty = any IP (still requires valid token).
ADMIN_ALLOWED_IPS=10.0.0.0/8,192.168.1.1,127.0.0.1

# ── 12.10 Swagger UI ─────────────────────────────────────────────────
# Interactive API explorer served at /docs (spec at /openapi.yaml).
SWAGGER_ENABLED=true               # set false to disable /docs entirely
SWAGGER_PROTECT=false              # set true to require ADMIN_TOKEN to load /docs itself
# Protect the docs page with HTTP Basic Auth. If BOTH are set, /docs and
# /openapi.yaml prompt for this username + password. Leave empty for open docs.
SWAGGER_USER=admin
SWAGGER_PASSWORD=change-me-please
